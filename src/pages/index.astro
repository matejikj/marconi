---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/sections/homepage/HeroSection.astro";
import WhatWeDoSection from "../components/sections/homepage/WhatWeDoSection.astro";
import InfrastructureSection from "../components/sections/homepage/InfrastructureSection.astro";
import SectorsSection from "../components/sections/homepage/SectorsSection.astro";
import ExperienceSection from "../components/sections/homepage/ExperienceSection.astro";
import CertificationsSection from "../components/sections/homepage/CertificationsSection.astro";
import SynergySection from "../components/sections/homepage/SynergySection.astro";
import FutureSection from "../components/sections/homepage/FutureSection.astro";
import ContactSection from "../components/sections/homepage/ContactSection.astro";
import HomepageMotionRuntime from "../components/islands/HomepageMotionRuntime.astro";
import {
  certificationsContent,
  contactContent,
  experienceContent,
  futureContent,
  heroContent,
  homepageMeta,
  infrastructureContent,
  sectorsContent,
  synergyContent,
  whatWeDoContent,
} from "../data/homepage";
---
<BaseLayout title={homepageMeta.title} description={homepageMeta.description}>
  <HeroSection {...heroContent} />
  <WhatWeDoSection {...whatWeDoContent} />
  <InfrastructureSection {...infrastructureContent} />
  <SectorsSection {...sectorsContent} />
  <ExperienceSection {...experienceContent} />
  <CertificationsSection {...certificationsContent} />
  <SynergySection {...synergyContent} />
  <FutureSection {...futureContent} />
  <ContactSection contact={contactContent} />
  <HomepageMotionRuntime />
</BaseLayout>
