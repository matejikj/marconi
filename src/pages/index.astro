---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Section from "../components/ui/Section.astro";
---
<BaseLayout>
  <Section id="hero" variant="light" spacing="lg">
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
      <div class="space-y-8">
        <p class="font-heading text-xs uppercase tracking-[0.16em] text-primary">
          Editorial Authority x Interactive Infrastructure
        </p>
        <h1 class="max-w-prose balance-text">
          Budujeme komunikacni infrastrukturu nove generace.
        </h1>
        <p class="text-prose text-body-lg">
          Systemova integrace a dodavky komunikacnich siti pro energetiku,
          telekomunikace, dopravu, verejnou spravu, obranu a bezpecnost.
        </p>
        <div class="flex flex-col gap-4 xs:flex-row">
          <Button href="#reseni">Nase reseni</Button>
          <Button href="#kontakt" variant="secondary">Kontaktujte nas</Button>
        </div>
      </div>

      <Card class="bg-bg-alt">
        <p class="mb-3 font-heading text-xs uppercase tracking-[0.16em] text-primary">Zaklad shellu</p>
        <p class="text-body">
          Tento layout je pripraveny pro implementaci homepage sekci, motion vrstvy a
          diagramu infrastruktury v dalsich tascich.
        </p>
      </Card>
    </div>
  </Section>

  <Section id="reseni" variant="alt" spacing="md" borderedTop={true}>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      <Card as="article">
        <h2 class="mb-3 text-2xl md:text-3xl">Design tokeny</h2>
        <p>Barvy, spacing, typografie a radius jsou napojene na CSS variables a Tailwind theme.</p>
      </Card>
      <Card as="article">
        <h2 class="mb-3 text-2xl md:text-3xl">UI komponenty</h2>
        <p>Button, Card, Section wrapper, Header, Footer a scroll progress bar placeholder.</p>
      </Card>
      <Card as="article" class="md:col-span-2 xl:col-span-1">
        <h2 class="mb-3 text-2xl md:text-3xl">A11y baseline</h2>
        <p>Focus states, skip link a reduced motion CSS fallback jsou pripraveny.</p>
      </Card>
    </div>
  </Section>

  <Section id="kontakt" variant="dark" spacing="sm">
    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
      <div class="space-y-4">
        <p class="font-heading text-xs uppercase tracking-[0.16em] text-primary">Dalsi krok</p>
        <h2 class="text-white">Pokračovat implementaci sekcí homepage a obsahu.</h2>
        <p class="max-w-prose text-slate-300">
          Task 01 je pripraven jako stabilni zaklad pro dalsi UX/UI a frontend praci.
        </p>
      </div>
      <div class="flex flex-col gap-4 sm:flex-row lg:flex-col lg:items-start">
        <Button href="#reseni">Zobrazit zaklad</Button>
        <Button href="#hero" variant="secondary" class="border-white text-white hover:bg-white/10">
          Zpet na zacatek
        </Button>
      </div>
    </div>
  </Section>
</BaseLayout>

