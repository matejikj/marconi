---
import Section from "../../ui/Section.astro";

interface Props {
  heading: string;
  body: string;
  items: string[];
}

const { heading, body, items } = Astro.props;
---
<Section id="certifikace" variant="light" spacing="md" borderedTop={true}>
  <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:gap-12">
    <div class="space-y-5">
      <p class="font-heading text-xs uppercase tracking-[0.16em] text-primary">Kvalita a bezpecnost</p>
      <h2 class="max-w-prose">{heading}</h2>
      <p class="text-prose">{body}</p>
    </div>

    <ul class="grid gap-4 sm:grid-cols-2" aria-label="Certifikace">
      {
        items.map((item) => (
          <li class="rounded-card border border-border bg-white px-5 py-4 text-base font-semibold text-text-main shadow-sm">
            {item}
          </li>
        ))
      }
    </ul>
  </div>
</Section>

