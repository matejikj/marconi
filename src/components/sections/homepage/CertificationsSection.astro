---
import Section from "../../ui/Section.astro";

interface Props {
  heading: string;
  body: string;
  items: string[];
}

const { heading, body, items } = Astro.props;
const sectionBgUrl = `${import.meta.env.BASE_URL}images/Minimal_abstract_architectural_network_background__7c920616f0.jpeg`;
---
<Section
  id="certifikace"
  variant="light"
  spacing="md"
  borderedTop={true}
  class="section-surface-image section-surface-image--light-emphasis"
  style={`--section-bg-image: url("${sectionBgUrl}")`}
>
  <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:gap-12">
    <div class="space-y-5" data-reveal>
      <p class="font-heading text-xs uppercase tracking-[0.16em] text-primary">Kvalita a bezpečnost</p>
      <h2 class="max-w-prose">{heading}</h2>
      <p class="text-prose">{body}</p>
    </div>

    <ul class="grid gap-4 sm:grid-cols-2" aria-label="Certifikace">
      {
        items.map((item, index) => (
          <li class="rounded-card border border-border bg-white px-5 py-4 text-base font-semibold text-text-main shadow-sm" data-reveal data-reveal-delay={String(Math.min(index + 1, 6))}>
            {item}
          </li>
        ))
      }
    </ul>
  </div>
</Section>
