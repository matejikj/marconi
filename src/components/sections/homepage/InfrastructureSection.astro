---
import Card from "../../ui/Card.astro";
import Section from "../../ui/Section.astro";
import type { InfrastructureStep } from "../../../data/homepage";

interface Props {
  heading: string;
  intro: string;
  closing: string;
  steps: InfrastructureStep[];
}

const { heading, intro, closing, steps } = Astro.props;
---
<Section id="infrastruktura" variant="alt" spacing="lg" borderedTop={true}>
  <div class="space-y-10">
    <div class="space-y-5">
      <p class="font-heading text-xs uppercase tracking-[0.16em] text-primary">Infrastruktura</p>
      <h2 class="max-w-prose">{heading}</h2>
      <p class="text-prose">{intro}</p>
    </div>

    <div class="hidden gap-8 lg:grid lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <figure class="overflow-hidden rounded-[20px] border border-border bg-white p-6 shadow-soft">
          <figcaption class="mb-4 text-sm font-medium text-text-secondary">
            Schema vrstvene komunikacni infrastruktury (SSR markup pro budouci interakci)
          </figcaption>
          <svg
            viewBox="0 0 560 420"
            class="h-auto w-full"
            role="img"
            aria-labelledby="infra-diagram-title infra-diagram-desc"
            data-infra-diagram
          >
            <title id="infra-diagram-title">Diagram infrastruktury TTC MARCONI</title>
            <desc id="infra-diagram-desc">
              Staticky diagram s peti uzly reprezentujicimi vrstvy reseni od IP komunikace po provozni dohled.
            </desc>

            <defs>
              <style>
                {`
                  .infra-line { stroke: #111827; stroke-width: 1.5; fill: none; opacity: 0.28; }
                  .infra-node { fill: #FFFFFF; stroke: #D1D5DB; stroke-width: 1.5; }
                  .infra-node--active { stroke: #01B5E5; fill: rgba(1,181,229,0.05); }
                  .infra-label { font: 600 13px Inter, system-ui, sans-serif; fill: #111827; }
                  .infra-meta { font: 500 11px Inter, system-ui, sans-serif; fill: #6B7280; letter-spacing: 0.08em; text-transform: uppercase; }
                `}
              </style>
            </defs>

            <path class="infra-line" d="M100 100 H280" />
            <path class="infra-line" d="M280 100 V170" />
            <path class="infra-line" d="M280 170 H460" />
            <path class="infra-line" d="M280 170 V250" />
            <path class="infra-line" d="M280 250 H120" />
            <path class="infra-line" d="M280 250 H440" />
            <path class="infra-line" d="M280 250 V330" />

            <g data-step-node="ip">
              <rect class="infra-node infra-node--active" x="36" y="64" rx="12" ry="12" width="128" height="72" />
              <text class="infra-meta" x="52" y="88">Vrstva 01</text>
              <text class="infra-label" x="52" y="112">IP reseni</text>
            </g>

            <g data-step-node="radio">
              <rect class="infra-node" x="216" y="64" rx="12" ry="12" width="128" height="72" />
              <text class="infra-meta" x="232" y="88">Vrstva 02</text>
              <text class="infra-label" x="232" y="112">Radiove site</text>
            </g>

            <g data-step-node="monitoring">
              <rect class="infra-node" x="396" y="134" rx="12" ry="12" width="128" height="72" />
              <text class="infra-meta" x="412" y="158">Vrstva 03</text>
              <text class="infra-label" x="412" y="182">Monitoring</text>
            </g>

            <g data-step-node="security">
              <rect class="infra-node" x="56" y="214" rx="12" ry="12" width="144" height="72" />
              <text class="infra-meta" x="72" y="238">Vrstva 04</text>
              <text class="infra-label" x="72" y="262">Bezpecnost dat</text>
            </g>

            <g data-step-node="ops">
              <rect class="infra-node" x="204" y="294" rx="12" ry="12" width="152" height="72" />
              <text class="infra-meta" x="220" y="318">Vrstva 05</text>
              <text class="infra-label" x="220" y="342">Provozni dohled 24/7</text>
            </g>
          </svg>
        </figure>
      </div>

      <div class="space-y-4">
        <ol class="space-y-4" aria-label="Kroky a vrstvy infrastruktury">
          {
            steps.map((step) => (
              <li>
                <Card
                  as="article"
                  class="group bg-white data-[active=true]:border-primary"
                  data-infra-step={step.id}
                  data-active={step.shortLabel === "01" ? "true" : "false"}
                >
                  <div class="flex items-start gap-4">
                    <div class="mt-1 inline-flex h-8 min-w-8 items-center justify-center rounded-full bg-primary-05 px-2 text-xs font-semibold tracking-[0.12em] text-primary">
                      {step.shortLabel}
                    </div>
                    <div class="space-y-2">
                      <h3 class="text-xl">{step.title}</h3>
                      <p>{step.description}</p>
                    </div>
                  </div>
                </Card>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <div class="space-y-4 lg:hidden">
      <div class="overflow-hidden rounded-[20px] border border-border bg-white p-4">
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">
          Diagram (mobilni fallback)
        </p>
        <svg viewBox="0 0 320 220" class="h-auto w-full" role="img" aria-label="Staticky diagram infrastruktury">
          <path d="M64 48 H160 V84 H256" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 84 V134" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 134 H64" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 134 H256" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 134 V184" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <circle cx="64" cy="48" r="12" fill="#01B5E5" fill-opacity="0.12" stroke="#01B5E5" />
          <circle cx="160" cy="48" r="12" fill="#fff" stroke="#D1D5DB" />
          <circle cx="256" cy="84" r="12" fill="#fff" stroke="#D1D5DB" />
          <circle cx="64" cy="134" r="12" fill="#fff" stroke="#D1D5DB" />
          <circle cx="160" cy="184" r="12" fill="#fff" stroke="#D1D5DB" />
          <text x="24" y="22" fill="#6B7280" font-size="11" font-family="Inter, system-ui, sans-serif">
            Vrstevnice infrastruktury
          </text>
        </svg>
      </div>

      <div class="space-y-3" aria-label="Kroky infrastruktury - mobilni accordion">
        {
          steps.map((step) => (
            <details class="rounded-card border border-border bg-white open:border-primary" data-infra-step={step.id}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4">
                <span class="flex items-center gap-3">
                  <span class="inline-flex h-7 min-w-7 items-center justify-center rounded-full bg-primary-05 px-2 text-xs font-semibold tracking-[0.12em] text-primary">
                    {step.shortLabel}
                  </span>
                  <span class="font-semibold text-text-main">{step.title}</span>
                </span>
                <span aria-hidden="true" class="text-text-muted">+</span>
              </summary>
              <div class="border-t border-border px-5 py-4">
                <p>{step.description}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>

    <p class="text-prose">{closing}</p>
  </div>
</Section>

