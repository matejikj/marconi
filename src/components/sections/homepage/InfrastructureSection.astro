---
import Card from "../../ui/Card.astro";
import Section from "../../ui/Section.astro";
import type { InfrastructureStep } from "../../../data/homepage";

interface Props {
  heading: string;
  intro: string;
  closing: string;
  steps: InfrastructureStep[];
}

const { heading, intro, closing, steps } = Astro.props;
---
<Section id="infrastruktura" variant="alt" spacing="lg" borderedTop={true}>
  <div class="space-y-10">
    <div class="space-y-5" data-reveal>
      <p class="font-heading text-xs uppercase tracking-[0.16em] text-primary">Infrastruktura</p>
      <h2 class="max-w-prose">{heading}</h2>
      <p class="text-prose">{intro}</p>
    </div>

    <div class="hidden gap-8 lg:grid lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <figure class="overflow-hidden rounded-[20px] border border-border bg-white p-6 shadow-soft" data-reveal data-reveal-delay="2">
          <figcaption class="mb-4 text-sm font-medium text-text-secondary">
            Schéma vrstvené komunikační infrastruktury (SSR markup pro budoucí interakci)
          </figcaption>
          <svg
            viewBox="0 0 560 420"
            class="infra-diagram h-auto w-full"
            role="img"
            aria-labelledby="infra-diagram-title infra-diagram-desc"
            data-infra-diagram
            style="forced-color-adjust: none;"
          >
            <title id="infra-diagram-title">Diagram infrastruktury TTC MARCONI</title>
            <desc id="infra-diagram-desc">
              Statický diagram s pěti uzly reprezentujícími vrstvy řešení od IP komunikace po provozní dohled.
            </desc>

            <defs>
              <style>
                {`
                  .infra-line { stroke: #111827; stroke-width: 1.5; fill: none; opacity: 0.28; stroke-dasharray: 680; stroke-dashoffset: 680; transition: stroke-dashoffset 900ms cubic-bezier(0.16,1,0.3,1); }
                  .infra-diagram[data-lines-ready="true"] .infra-line { stroke-dashoffset: 0; }
                  .infra-node { fill: #FFFFFF; stroke: #D1D5DB; stroke-width: 1.5; transition: fill 300ms cubic-bezier(0.22,1,0.36,1), stroke 300ms cubic-bezier(0.22,1,0.36,1), transform 300ms cubic-bezier(0.22,1,0.36,1); transform-box: fill-box; transform-origin: center; }
                  .infra-node--active { stroke: #01B5E5; fill: rgba(1,181,229,0.05); }
                  .infra-node-group[data-hovered="true"] .infra-node,
                  .infra-node-group:focus .infra-node,
                  .infra-node-group:hover .infra-node { stroke: #01B5E5; fill: rgba(1,181,229,0.05); transform: scale(1.06); }
                  .infra-label { font: 600 13px Inter, system-ui, sans-serif; fill: #111827; }
                  .infra-meta { font: 500 11px Inter, system-ui, sans-serif; fill: #6B7280; letter-spacing: 0.08em; text-transform: uppercase; }
                `}
              </style>
            </defs>

            <path class="infra-line" d="M164 100 H216" fill="none" stroke="#111827" opacity="0.28" />
            <path class="infra-line" d="M280 136 V170" fill="none" stroke="#111827" opacity="0.28" />
            <path class="infra-line" d="M280 170 H396" fill="none" stroke="#111827" opacity="0.28" />
            <path class="infra-line" d="M280 170 V250" fill="none" stroke="#111827" opacity="0.28" />
            <path class="infra-line" d="M280 250 H200" fill="none" stroke="#111827" opacity="0.28" />
            <path class="infra-line" d="M280 250 V294" fill="none" stroke="#111827" opacity="0.28" />

            <g class="infra-node-group" data-step-node="ip" data-active="true" tabindex="0" focusable="true" role="button" aria-label="IP komunikační řešení">
              <rect class="infra-node infra-node--active" x="36" y="64" rx="12" ry="12" width="128" height="72" fill="rgba(1,181,229,0.05)" stroke="#01B5E5" />
              <text class="infra-meta" x="52" y="88" fill="#6B7280">Vrstva 01</text>
              <text class="infra-label" x="52" y="112" fill="#111827">IP řešení</text>
            </g>

            <g class="infra-node-group" data-step-node="radio" data-active="false" tabindex="0" focusable="true" role="button" aria-label="Rádiové sítě">
              <rect class="infra-node" x="216" y="64" rx="12" ry="12" width="128" height="72" fill="#FFFFFF" stroke="#D1D5DB" />
              <text class="infra-meta" x="232" y="88" fill="#6B7280">Vrstva 02</text>
              <text class="infra-label" x="232" y="112" fill="#111827">Rádiové sítě</text>
            </g>

            <g class="infra-node-group" data-step-node="monitoring" data-active="false" tabindex="0" focusable="true" role="button" aria-label="Síťový monitoring">
              <rect class="infra-node" x="396" y="134" rx="12" ry="12" width="128" height="72" fill="#FFFFFF" stroke="#D1D5DB" />
              <text class="infra-meta" x="412" y="158" fill="#6B7280">Vrstva 03</text>
              <text class="infra-label" x="412" y="182" fill="#111827">Monitoring</text>
            </g>

            <g class="infra-node-group" data-step-node="security" data-active="false" tabindex="0" focusable="true" role="button" aria-label="Bezpečnost a ochrana dat">
              <rect class="infra-node" x="56" y="214" rx="12" ry="12" width="144" height="72" fill="#FFFFFF" stroke="#D1D5DB" />
              <text class="infra-meta" x="72" y="238" fill="#6B7280">Vrstva 04</text>
              <text class="infra-label" x="72" y="262" fill="#111827">Bezpečnost dat</text>
            </g>

            <g class="infra-node-group" data-step-node="ops" data-active="false" tabindex="0" focusable="true" role="button" aria-label="Provozní dohled 24 hodin denně 7 dní v týdnu">
              <rect class="infra-node" x="204" y="294" rx="12" ry="12" width="152" height="72" fill="#FFFFFF" stroke="#D1D5DB" />
              <text class="infra-meta" x="220" y="318" fill="#6B7280">Vrstva 05</text>
              <text class="infra-label" x="220" y="342" fill="#111827">Provozní dohled 24/7</text>
            </g>
          </svg>
        </figure>
      </div>

      <div class="space-y-4" data-reveal data-reveal-delay="3">
        <ol class="space-y-4" aria-label="Kroky a vrstvy infrastruktury">
          {
            steps.map((step, index) => (
              <li>
                <Card
                  as="article"
                  class="group bg-white data-[active=true]:border-primary data-[active=true]:bg-primary-05"
                  data-infra-step={step.id}
                  data-active={step.shortLabel === "01" ? "true" : "false"}
                  data-reveal
                  data-reveal-delay={String(Math.min(index + 1, 6))}
                >
                  <div class="flex items-start gap-4">
                    <div class="mt-1 inline-flex h-8 min-w-8 items-center justify-center rounded-full bg-primary-05 px-2 text-xs font-semibold tracking-[0.12em] text-primary">
                      {step.shortLabel}
                    </div>
                    <div class="space-y-2">
                      <h3 class="text-xl">{step.title}</h3>
                      <p>{step.description}</p>
                    </div>
                  </div>
                </Card>
              </li>
            ))
          }
        </ol>
      </div>
    </div>

    <div class="space-y-4 lg:hidden">
      <div class="overflow-hidden rounded-[20px] border border-border bg-white p-4" data-reveal>
        <p class="mb-3 text-xs font-semibold uppercase tracking-[0.12em] text-text-muted">
          Diagram (mobilní fallback)
        </p>
        <svg viewBox="0 0 320 220" class="h-auto w-full" role="img" aria-label="Statický diagram infrastruktury" style="forced-color-adjust: none;">
          <path d="M64 48 H160 V84 H256" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 84 V134" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 134 H64" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 134 H256" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <path d="M160 134 V184" fill="none" stroke="#111827" stroke-width="1.4" opacity="0.3" />
          <circle cx="64" cy="48" r="12" fill="#01B5E5" fill-opacity="0.12" stroke="#01B5E5" />
          <circle cx="160" cy="48" r="12" fill="#fff" stroke="#D1D5DB" />
          <circle cx="256" cy="84" r="12" fill="#fff" stroke="#D1D5DB" />
          <circle cx="64" cy="134" r="12" fill="#fff" stroke="#D1D5DB" />
          <circle cx="160" cy="184" r="12" fill="#fff" stroke="#D1D5DB" />
          <text x="24" y="22" fill="#6B7280" font-size="11" font-family="Inter, system-ui, sans-serif">
            Vrstvenice infrastruktury
          </text>
        </svg>
      </div>

      <div class="space-y-3" aria-label="Kroky infrastruktury - mobilní akordeon">
        {
          steps.map((step, index) => (
            <details class="rounded-card border border-border bg-white open:border-primary data-[active=true]:border-primary data-[active=true]:bg-primary-05" data-infra-step={step.id} data-active={step.shortLabel === "01" ? "true" : "false"} open={step.shortLabel === "01"} data-reveal data-reveal-delay={String(Math.min(index + 1, 6))}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4">
                <span class="flex items-center gap-3">
                  <span class="inline-flex h-7 min-w-7 items-center justify-center rounded-full bg-primary-05 px-2 text-xs font-semibold tracking-[0.12em] text-primary">
                    {step.shortLabel}
                  </span>
                  <span class="font-semibold text-text-main">{step.title}</span>
                </span>
                <span aria-hidden="true" class="text-text-muted">+</span>
              </summary>
              <div class="border-t border-border px-5 py-4">
                <p>{step.description}</p>
              </div>
            </details>
          ))
        }
      </div>
    </div>

    <p class="text-prose" data-reveal data-reveal-delay="2">{closing}</p>
  </div>
</Section>
