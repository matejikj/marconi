---
import Section from "../../ui/Section.astro";

interface Props {
  heading: string;
  paragraphs: string[];
}

const { heading, paragraphs } = Astro.props;
---
<Section id="budoucnost" variant="light" spacing="md" borderedTop={true}>
  <div class="grid gap-8 lg:grid-cols-[1fr_0.85fr] lg:gap-12">
    <div class="space-y-5">
      <p class="font-heading text-xs uppercase tracking-[0.16em] text-primary">Pohled do budoucnosti</p>
      <h2 class="max-w-prose">{heading}</h2>
      <div class="max-w-prose space-y-4">
        {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>

    <aside class="rounded-[20px] border border-border bg-bg-alt p-8">
      <div class="mb-5 h-0.5 w-16 bg-primary"></div>
      <p class="text-sm font-semibold uppercase tracking-[0.12em] text-text-muted">Principy navrhu</p>
      <ul class="mt-4 space-y-3 text-body text-text-secondary">
        <li>Skalovatelnost architektury</li>
        <li>Kyberneticka bezpecnost jako soucast navrhu</li>
        <li>Dlouhodoba provozni udrzitelnost</li>
      </ul>
    </aside>
  </div>
</Section>

