---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  type?: "button" | "submit" | "reset";
  class?: string;
  ariaLabel?: string;
}

const {
  href,
  variant = "primary",
  type = "button",
  class: className = "",
  ariaLabel,
} = Astro.props;

const baseClass =
  "inline-flex items-center justify-center rounded-full px-7 py-4 text-sm font-semibold tracking-[0.02em] transition-all duration-fast ease-power2-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2";

const variantClass =
  variant === "secondary"
    ? "border border-primary bg-transparent text-primary hover:-translate-y-0.5 hover:bg-primary-05"
    : "border border-primary bg-primary text-white shadow-soft hover:-translate-y-0.5 hover:brightness-95";

const classes = `${baseClass} ${variantClass} ${className}`.trim();
---
{
  href ? (
    <a class={classes} href={href} aria-label={ariaLabel}>
      <slot />
    </a>
  ) : (
    <button class={classes} type={type} aria-label={ariaLabel}>
      <slot />
    </button>
  )
}

