---
import Button from "./Button.astro";
import { primaryNav } from "../../data/navigation";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---
<header class="site-header" data-header data-scrolled="false">
  <div class="site-header__inner">
    <a
      href="/"
      class="flex items-center gap-3 text-sm font-semibold tracking-[0.12em] text-text-main"
      aria-label="TTC MARCONI - domovska stranka"
    >
      <span class="inline-block h-2.5 w-2.5 rounded-full bg-primary" aria-hidden="true"></span>
      <span class="font-heading text-xs uppercase tracking-[0.16em]">TTC MARCONI</span>
    </a>

    <nav aria-label="Hlavni navigace" class="hidden items-center gap-8 lg:flex">
      {
        primaryNav.map((item) => (
          <a
            href={item.href}
            class="ui-link-underline text-sm font-medium text-text-secondary transition-colors duration-fast ease-power2-out hover:text-primary"
            data-active={currentPath === item.href ? "true" : "false"}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden lg:block">
      <Button href="#kontakt" variant="secondary">Kontakt</Button>
    </div>

    <button
      type="button"
      class="inline-flex items-center justify-center rounded-full border border-border bg-white p-3 text-text-main lg:hidden"
      aria-label="Otevrit navigaci"
      data-mobile-nav-trigger
    >
      <span class="sr-only">Menu</span>
      <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
      </svg>
    </button>
  </div>
</header>

