---
import Button from "./Button.astro";
import { primaryNav } from "../../data/navigation";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---
<header class="site-header" data-header data-scrolled="false" data-mobile-nav-open="false">
  <div class="site-header__inner">
    <a
      href="/"
      class="flex items-center gap-3 text-sm font-semibold tracking-[0.12em] text-text-main"
      aria-label="TTC MARCONI - domovská stránka"
    >
      <span class="inline-block h-2.5 w-2.5 rounded-full bg-primary" aria-hidden="true"></span>
      <span class="font-heading text-xs uppercase tracking-[0.16em]">TTC MARCONI</span>
    </a>

    <div class="hidden items-center gap-3 lg:flex">
      <div class="site-header__desktop-nav-shell">
        <nav aria-label="Hlavní navigace" class="site-header__desktop-nav">
          {
            primaryNav.map((item) => (
              <a
                href={item.href}
                class="ui-link-underline text-sm font-medium text-text-secondary transition-colors duration-fast ease-power2-out hover:text-primary"
                data-active={currentPath === item.href ? "true" : "false"}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>

      <Button href="#kontakt" variant="secondary">Kontakt</Button>
    </div>

    <button
      type="button"
      class="site-header__mobile-trigger inline-flex items-center justify-center rounded-full border border-border bg-white p-3 text-text-main lg:hidden"
      aria-label="Otevřít navigaci"
      aria-expanded="false"
      aria-controls="mobile-nav-panel"
      data-mobile-nav-trigger
    >
      <span class="sr-only">Menu</span>
      <span class="site-header__burger" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </div>

  <div class="site-header__mobile-layer lg:hidden" data-mobile-nav-layer aria-hidden="true" inert>
    <button
      type="button"
      class="site-header__mobile-backdrop"
      aria-label="Zavřít navigaci"
      tabindex="-1"
      data-mobile-nav-backdrop
    ></button>

    <div
      id="mobile-nav-panel"
      class="site-header__mobile-panel"
      role="dialog"
      aria-modal="true"
      aria-label="Mobilní navigace"
      tabindex="-1"
      data-mobile-nav-panel
    >
      <nav aria-label="Mobilní navigace" class="site-header__mobile-nav">
        {
          primaryNav.map((item) => (
            <a
              href={item.href}
              class="site-header__mobile-link"
              data-active={currentPath === item.href ? "true" : "false"}
              data-mobile-nav-link
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="mt-2 flex flex-col gap-3">
        <Button href="#kontakt">Kontaktovat tým</Button>
        <Button href="#hero" variant="secondary">Zpět na začátek</Button>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector("[data-header]");

  if (header && !header.hasAttribute("data-mobile-nav-bound")) {
    header.setAttribute("data-mobile-nav-bound", "true");

    const trigger = header.querySelector("[data-mobile-nav-trigger]");
    const layer = header.querySelector("[data-mobile-nav-layer]");
    const panel = header.querySelector("[data-mobile-nav-panel]");
    const backdrop = header.querySelector("[data-mobile-nav-backdrop]");
    const links = header.querySelectorAll("[data-mobile-nav-link]");
    const desktopMedia = window.matchMedia("(min-width: 1024px)");
    const previousOverflow = document.body.style.overflow;

    const setOpen = (open) => {
      header.dataset.mobileNavOpen = open ? "true" : "false";
      if (trigger instanceof HTMLElement) {
        trigger.setAttribute("aria-expanded", open ? "true" : "false");
      }
      if (layer instanceof HTMLElement) {
        layer.setAttribute("aria-hidden", open ? "false" : "true");
        if ("inert" in layer) {
          layer.inert = !open;
        }
      }
      document.body.style.overflow = open ? "hidden" : previousOverflow;

      if (open && panel instanceof HTMLElement) {
        window.requestAnimationFrame(() => panel.focus());
      }
    };

    const close = () => setOpen(false);
    const toggle = () => setOpen(header.dataset.mobileNavOpen !== "true");

    trigger?.addEventListener("click", toggle);
    backdrop?.addEventListener("click", close);
    links.forEach((link) => link.addEventListener("click", close));

    header.addEventListener("keydown", (event) => {
      if (event.key === "Escape") close();
    });

    document.addEventListener("click", (event) => {
      if (header.dataset.mobileNavOpen !== "true") return;
      if (!(event.target instanceof Node)) return;
      if (!header.contains(event.target)) close();
    });

    desktopMedia.addEventListener("change", (event) => {
      if (event.matches) close();
    });
  }
</script>
