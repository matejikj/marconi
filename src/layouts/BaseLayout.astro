---
import Header from "../components/ui/Header.astro";
import Footer from "../components/ui/Footer.astro";
import ScrollProgressBar from "../components/ui/ScrollProgressBar.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "TTC MARCONI | Komunikační infrastruktura",
  description = "Systémová integrace a dodávky komunikačních sítí pro kritickou infrastrukturu.",
} = Astro.props;
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
  </head>
  <body class="site-shell">
    <a class="sr-skip-link" href="#main-content">Přeskočit na obsah</a>
    <ScrollProgressBar />
    <Header />
    <main id="main-content" class="site-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
